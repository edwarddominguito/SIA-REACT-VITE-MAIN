PORT=3000
NODE_ENV=development

# Database selection
# Supabase-first default:
DB_CLIENT=postgres

# Supabase/Postgres (recommended for cloud)
# Use the Transaction pooler URI from Supabase:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
DB_SSL=true

# Supabase Auth bridge (required for Google Sign-In flow)
SUPABASE_URL=https://jtstkfpzrhjbqqkfmtvw.supabase.co
SUPABASE_ANON_KEY=

# MySQL connection (for local mysql only)
# Switch DB_CLIENT=mysql if you use this block.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=sia_realestate

# Optional server tuning
REQUEST_SIZE_LIMIT=200kb
IDEMPOTENCY_TTL_MS=30000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30

# Optional Google Calendar sync for demo/customer scheduling
# After setting CLIENT_ID and CLIENT_SECRET, run `npm run google-calendar:token`
# inside the backend folder to save GOOGLE_CALENDAR_REFRESH_TOKEN automatically.
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIME_ZONE=Asia/Manila
GOOGLE_CALENDAR_SYNC_TIMEOUT_MS=8000
GOOGLE_CALENDAR_SEND_UPDATES=none
GOOGLE_CALENDAR_APPOINTMENT_DURATION_MINUTES=60
GOOGLE_CALENDAR_MEETING_DURATION_MINUTES=60
GOOGLE_CALENDAR_TRIP_DURATION_MINUTES=120

# Optional httpSMS integration for SMS conversations between users
HTTPSMS_ENABLED=false
HTTPSMS_API_BASE_URL=https://api.httpsms.com
HTTPSMS_API_KEY=
# Your registered httpSMS sender/owner phone number
HTTPSMS_FROM=
# Used to normalize local numbers like 09xxxxxxxxx into E.164 format (+63...)
HTTPSMS_DEFAULT_COUNTRY_CODE=63
HTTPSMS_TIMEOUT_MS=8000
# Optional: verify signed httpSMS webhooks if you configure webhook signing
HTTPSMS_WEBHOOK_SIGNING_SECRET=
